# ============================================================
# SmartPicksProAI — Environment Variables
# ============================================================
# Copy this file to `.env` and fill in the values you need.
#
#   cp .env.example .env
#
# Only ODDS_API_KEY is required for live odds integration.
# The app runs without any env vars (predictions, projections,
# and the full pipeline work offline using NBA API public data).
# ============================================================

# ── The Odds API (https://the-odds-api.com) ──────────────────
# Required for live sportsbook odds / prop lines.
# Free tier: 500 requests/month.
ODDS_API_KEY=

# ── PrizePicks API (optional) ────────────────────────────────
# Override the default PrizePicks API base URL.
# Leave blank to use the built-in default.
# PRIZEPICKS_API_URL=https://api.prizepicks.com/projections

# ── Underdog Fantasy API (optional) ──────────────────────────
# Override the default Underdog Fantasy API base URL.
# Leave blank to use the built-in default.
# UNDERDOG_API_URL=https://api.underdogfantasy.com/v1
